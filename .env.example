# Admin password para /admin. REQUIRED en producción.
# En dev podés dejarlo sin setear (cae a "padel2026").
ADMIN_PASSWORD=

# Upstash Redis para persistir el estado del torneo.
# REQUIRED en producción (Vercel filesystem es read-only).
# En dev, si no están seteadas, persiste en .tournament-state.json local.
# La integración Upstash de Vercel setea KV_REST_API_* automáticamente.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alias aceptados (si usás Upstash sin la integración de Vercel).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
